require 'shellwords'
require 'fileutils'

default_platform(:ios)

def env_present?(key)
  value = ENV[key]
  !value.nil? && !value.strip.empty?
end

# Parses the Name/UUID out of a .mobileprovision, so we don't depend on
# guessing which lane_context/env var a given fastlane action stashed them in.
def read_provisioning_profile_info(path)
  xml = sh("security cms -D -i #{path.shellescape}", log: false)
  name = xml[/<key>Name<\/key>\s*<string>([^<]*)<\/string>/, 1]
  uuid = xml[/<key>UUID<\/key>\s*<string>([^<]*)<\/string>/, 1]
  UI.user_error!("Could not read Name/UUID out of provisioning profile at #{path}") unless name && uuid
  { name: name, uuid: uuid }
end

# Path match's readonly fetch or the cert/sigh+cache path both feed here:
# switch the Xcode project off Automatic signing (which needs a logged-in
# Apple ID Xcode doesn't have on CI) onto the manual profile we just secured,
# and hand flutter an ExportOptions.plist that matches it.
def apply_code_signing(bundle_id:, team_id:, profile_name:)
  export_options_path = File.expand_path("../ios/ExportOptions.plist", __dir__)

  update_code_signing_settings(
    path: "ios/Runner.xcodeproj",
    use_automatic_signing: false,
    team_id: team_id,
    code_sign_identity: "Apple Distribution",
    bundle_identifier: bundle_id,
    profile_name: profile_name,
    targets: ["Runner"]
  )

  File.write(export_options_path, <<~PLIST)
    <?xml version="1.0" encoding="UTF-8"?>
    <!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
    <plist version="1.0">
    <dict>
      <key>method</key>
      <string>app-store</string>
      <key>teamID</key>
      <string>#{team_id}</string>
      <key>signingStyle</key>
      <string>manual</string>
      <key>provisioningProfiles</key>
      <dict>
        <key>#{bundle_id}</key>
        <string>#{profile_name}</string>
      </dict>
    </dict>
    </plist>
  PLIST

  export_options_path
end

# Preferred path when a match git repo is configured (MATCH_GIT_URL secret
# set): readonly fetch only, CI never mints/revokes certs this way.
def signing_via_match(bundle_id:, api_key:)
  match(
    type: "appstore",
    readonly: true,
    app_identifier: bundle_id,
    git_url: ENV['MATCH_GIT_URL'],
    username: ENV['APPLE_ID'],
    api_key: api_key
  )

  profile_name = ENV["sigh_#{bundle_id}_appstore_profile-name"]
  UI.user_error!("match ran but no profile name was found in the environment") unless profile_name
  profile_name
end

# Fallback path when there's no match repo: create (once) a Distribution
# certificate + App Store provisioning profile straight from the App Store
# Connect API key, export them as a .p12/.mobileprovision into
# ios_signing_cache/, and reuse that cache on every later run instead of
# minting a new certificate each time (Apple caps an account at 3 active
# distribution certs). ios_release.yml caches that directory across runs.
def signing_via_cert_and_sigh(bundle_id:, team_id:, api_key:)
  cache_dir = File.expand_path("../ios_signing_cache", __dir__)
  FileUtils.mkdir_p(cache_dir)

  p12_path = File.join(cache_dir, "distribution.p12")
  profile_path = File.join(cache_dir, "AppStore.mobileprovision")
  p12_password = env_present?('P12_EXPORT_PASSWORD') ? ENV['P12_EXPORT_PASSWORD'] : "ci-signing-cache"

  # create_keychain resolves a bare name against ~/Library/Keychains/ fine
  # (as does import_certificate's keychain_name:), but `cert`'s
  # keychain_path: does NOT do that resolution — it needs the real absolute
  # path, and macOS's modern keychain format silently appends "-db" to
  # whatever name you give `security create-keychain`.
  keychain_name = "ci-build.keychain"
  keychain_file = File.expand_path("~/Library/Keychains/#{keychain_name}-db")
  keychain_password = "ci-build-pass"

  create_keychain(
    name: keychain_name,
    password: keychain_password,
    default_keychain: true,
    unlock: true,
    timeout: 1800
  )

  if File.exist?(p12_path) && File.exist?(profile_path)
    UI.message("Found cached signing assets in ios_signing_cache/ — reusing them instead of minting a new certificate.")
    import_certificate(
      certificate_path: p12_path,
      certificate_password: p12_password,
      keychain_name: keychain_name,
      keychain_password: keychain_password
    )
  else
    UI.message("No cached signing assets found — creating a new Distribution certificate + App Store profile via the App Store Connect API key.")
    cert(
      output_path: cache_dir,
      keychain_path: keychain_file,
      username: ENV['APPLE_ID'],
      team_id: team_id,
      api_key: api_key
    )
    sigh(
      app_identifier: bundle_id,
      team_id: team_id,
      api_key: api_key,
      output_path: cache_dir,
      filename: "AppStore.mobileprovision"
    )

    sh("security export -k #{keychain_file.shellescape} -t identities -f pkcs12 -o #{p12_path.shellescape} -P #{p12_password.shellescape}")
    UI.user_error!("cert/sigh ran but no signing assets ended up in #{cache_dir}") unless File.exist?(p12_path) && File.exist?(profile_path)
  end

  # Let codesign/xcodebuild use the imported key non-interactively.
  sh("security set-key-partition-list -S apple-tool:,apple: -s -k #{keychain_password.shellescape} #{keychain_file.shellescape}", log: false)

  profile_info = read_provisioning_profile_info(profile_path)

  profiles_dir = File.expand_path("~/Library/MobileDevice/Provisioning Profiles")
  FileUtils.mkdir_p(profiles_dir)
  FileUtils.cp(profile_path, File.join(profiles_dir, "#{profile_info[:uuid]}.mobileprovision"))

  profile_info[:name]
end

platform :ios do
  desc "Build and upload to TestFlight using the App Store Connect API key"
  lane :beta do
    key_contents = if env_present?('APP_STORE_CONNECT_PRIVATE_KEY_BASE64')
      Base64.decode64(ENV['APP_STORE_CONNECT_PRIVATE_KEY_BASE64'])
    elsif ENV['APP_AUTH_KEY_PATH'] && File.exist?(ENV['APP_AUTH_KEY_PATH'])
      File.read(ENV['APP_AUTH_KEY_PATH'])
    else
      UI.user_error!("Missing App Store Connect private key. Set APP_STORE_CONNECT_PRIVATE_KEY_BASE64 or APP_AUTH_KEY_PATH.")
    end

    api_key = app_store_connect_api_key(
      key_id: ENV['APP_STORE_CONNECT_KEY_ID'],
      issuer_id: ENV['APP_STORE_CONNECT_ISSUER_ID'],
      key_content: key_contents
    )

    bundle_id = ENV['BUNDLE_ID'] || "com.melih.tacticaleleven"
    team_id = ENV['TEAM_ID']

    profile_name = if env_present?('MATCH_GIT_URL')
      signing_via_match(bundle_id: bundle_id, api_key: api_key)
    else
      signing_via_cert_and_sigh(bundle_id: bundle_id, team_id: team_id, api_key: api_key)
    end

    export_options_path = apply_code_signing(bundle_id: bundle_id, team_id: team_id, profile_name: profile_name)

    sh("flutter pub get")

    flutter_build_args = []
    flutter_build_args << "--build-name=#{Shellwords.escape(ENV['FLUTTER_BUILD_NAME'])}" if env_present?('FLUTTER_BUILD_NAME')
    flutter_build_args << "--build-number=#{Shellwords.escape(ENV['FLUTTER_BUILD_NUMBER'])}" if env_present?('FLUTTER_BUILD_NUMBER')
    flutter_build_args << "--export-options-plist=#{Shellwords.escape(export_options_path)}"
    flutter_build_args << "--dart-define=SUPABASE_URL=#{Shellwords.escape(ENV['SUPABASE_URL'])}" if env_present?('SUPABASE_URL')
    flutter_build_args << "--dart-define=SUPABASE_ANON_KEY=#{Shellwords.escape(ENV['SUPABASE_ANON_KEY'])}" if env_present?('SUPABASE_ANON_KEY')
    flutter_build_args << "--dart-define=REVENUECAT_API_KEY=#{Shellwords.escape(ENV['REVENUECAT_API_KEY'])}" if env_present?('REVENUECAT_API_KEY')
    flutter_build_args << "--dart-define=ADMOB_INTERSTITIAL_ID=#{Shellwords.escape(ENV['ADMOB_INTERSTITIAL_ID'])}" if env_present?('ADMOB_INTERSTITIAL_ID')

    sh("flutter build ipa --release #{flutter_build_args.join(' ')}")

    upload_to_app_store(
      ipa: "build/ios/ipa/Runner.ipa",
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end
